{
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://5yolv6hec8.execute-api.ap-southeast-1.amazonaws.com/api/:path*"
    },
    {
      "source": "/webhook",
      "destination": "https://5yolv6hec8.execute-api.ap-southeast-1.amazonaws.com/webhook"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
